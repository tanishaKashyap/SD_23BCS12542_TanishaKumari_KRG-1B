  <diagram name="Page-1" id="TF0Fan6gxghBc9Q8q-D_">
    <mxGraphModel dx="1747" dy="3093" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="8HRzVfL3QyexAWrj1ium-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h3 data-path-to-node=&quot;3&quot; style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;3&quot; data-index-in-node=&quot;0&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Experiment 04: To design a video streaming platform similar to YouTube&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;h3 data-path-to-node=&quot;4&quot; style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;4&quot; data-index-in-node=&quot;0&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font size=&quot;3&quot;&gt;1. Functional Requirements&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;h2 data-path-to-node=&quot;2&quot;&gt;&lt;p data-path-to-node=&quot;5&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;5&quot; data-index-in-node=&quot;0&quot; style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;A.&lt;/span&gt;&lt;span style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; User should be able to register, login.&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;5&quot; data-index-in-node=&quot;65&quot; style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;B.&lt;/span&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; User should be able to upload videos (support for metadata like titles and tags).&lt;/span&gt;&lt;/div&gt;&lt;font size=&quot;3&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;5&quot; data-index-in-node=&quot;150&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;C. User should be able to change the video quality as per their choice.&lt;/span&gt;&lt;/div&gt;&lt;span data-path-to-node=&quot;5&quot; data-index-in-node=&quot;205&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;5&quot; data-index-in-node=&quot;205&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;D.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; User should be able to like, dislike, or comment on videos.&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;5&quot; data-index-in-node=&quot;268&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;5&quot; data-index-in-node=&quot;268&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;E.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; User should be able to view a home feed based on recommendations.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;/h2&gt;&lt;h3 data-path-to-node=&quot;6&quot; style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;6&quot; data-index-in-node=&quot;0&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font size=&quot;3&quot;&gt;2. Non-Functional Requirements&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;h2 data-path-to-node=&quot;2&quot;&gt;&lt;p data-path-to-node=&quot;7&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;7&quot; data-index-in-node=&quot;0&quot; style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;A. Scalability:&lt;/span&gt;&lt;span style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; 2B+ Monthly Active Users (MAU) and 500 hours of video uploaded per minute.&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;B. Consistency &amp;amp; Availability:&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;p data-path-to-node=&quot;8&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;In this case -&amp;gt; Video Streaming&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;32&quot; style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1.&lt;/span&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; We need the application to be HIGHLY available, then consistent.&lt;/span&gt;&lt;/div&gt;&lt;font size=&quot;3&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;100&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Reason:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; If a video is unavailable when a user wants to watch it, they will leave the platform. High availability ensures the playback service is always reachable.&lt;/span&gt;&lt;/div&gt;&lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;263&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;263&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Eg:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; If the view count takes 2 seconds to update (Eventual Consistency), it is not a major issue compared to the video failing to load (Availability).&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;413&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;413&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Hence:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Availability &amp;gt;&amp;gt;&amp;gt;&amp;gt; Consistency.&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;451&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;451&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;C. Latency:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Playback should start within 200ms; minimal buffering for a smooth experience.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;/h2&gt;&lt;h3 data-path-to-node=&quot;9&quot; style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;9&quot; data-index-in-node=&quot;0&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font size=&quot;3&quot;&gt;3. Core Entities&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;h2 data-path-to-node=&quot;2&quot;&gt;&lt;p data-path-to-node=&quot;10&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;10&quot; data-index-in-node=&quot;0&quot; style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;A.&lt;/span&gt;&lt;span style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Users / Channels&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;10&quot; data-index-in-node=&quot;20&quot; style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;B.&lt;/span&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Videos (Metadata and Video Chunks)&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;p data-path-to-node=&quot;11&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;11&quot; data-index-in-node=&quot;0&quot; style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;C.&lt;/span&gt;&lt;span style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Subscriptions&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;11&quot; data-index-in-node=&quot;17&quot; style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;D.&lt;/span&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Likes, Dislikes &amp;amp; Comments&lt;/span&gt;&lt;/div&gt;&lt;font size=&quot;3&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;11&quot; data-index-in-node=&quot;47&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;E.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Playlists &amp;amp; Watch History&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;/h2&gt;&lt;h3 data-path-to-node=&quot;12&quot; style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;12&quot; data-index-in-node=&quot;0&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font size=&quot;3&quot;&gt;4. API Endpoints&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;h4 data-path-to-node=&quot;13&quot; style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;13&quot; data-index-in-node=&quot;0&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font size=&quot;3&quot;&gt;A. User &amp;amp; Channel APIs&lt;/font&gt;&lt;/span&gt;&lt;/h4&gt;&lt;h2 data-path-to-node=&quot;2&quot;&gt;&lt;p data-path-to-node=&quot;14&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;14&quot; data-index-in-node=&quot;0&quot; style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. User Registration:&lt;/span&gt;&lt;span style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; POST /api/v1/users/register&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;14&quot; data-index-in-node=&quot;50&quot; style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2. User Login:&lt;/span&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; POST /api/v1/users/login&lt;/span&gt;&lt;/div&gt;&lt;font size=&quot;3&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;14&quot; data-index-in-node=&quot;90&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3. Channel Profile Display:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; GET /api/v1/channels/{channel_id}&lt;/span&gt;&lt;/div&gt;&lt;span data-path-to-node=&quot;14&quot; data-index-in-node=&quot;152&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;14&quot; data-index-in-node=&quot;152&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4. Channel Profile Update:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; PUT /api/v1/channels/{channel_id}&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;/h2&gt;&lt;h4 data-path-to-node=&quot;15&quot; style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;15&quot; data-index-in-node=&quot;0&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font size=&quot;3&quot;&gt;B. Video Management APIs&lt;/font&gt;&lt;/span&gt;&lt;/h4&gt;&lt;h2 data-path-to-node=&quot;2&quot;&gt;&lt;p data-path-to-node=&quot;16&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;0&quot; style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. Upload Video:&lt;/span&gt;&lt;span style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; POST /api/v1/videos/upload&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;44&quot; style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2. Get Video Details:&lt;/span&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; GET /api/v1/videos/{video_id}&lt;/span&gt;&lt;/div&gt;&lt;font size=&quot;3&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;96&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3. Update Video Metadata:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; PUT /api/v1/videos/{video_id}&lt;/span&gt;&lt;/div&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;152&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;152&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4. Delete Video:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; DELETE /api/v1/videos/{video_id}&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;202&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;202&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;5. Fetch Home Feed:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; GET /api/v1/videos/feed?limit={limit}&amp;amp;offset={offset}&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;276&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;16&quot; data-index-in-node=&quot;276&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;6. Fetch Subscription Feed:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; GET /api/v1/users/{user_id}/subscriptions/feed&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;/h2&gt;&lt;h4 data-path-to-node=&quot;17&quot; style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;17&quot; data-index-in-node=&quot;0&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font size=&quot;3&quot;&gt;C. User Interactions&lt;/font&gt;&lt;/span&gt;&lt;/h4&gt;&lt;h2 data-path-to-node=&quot;2&quot;&gt;&lt;p data-path-to-node=&quot;18&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;0&quot; style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. Like Video:&lt;/span&gt;&lt;span style=&quot;font-size: medium; font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; POST /api/v1/videos/{video_id}/like&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;51&quot; style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2. Remove Like:&lt;/span&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; DELETE /api/v1/videos/{video_id}/unlike&lt;/span&gt;&lt;/div&gt;&lt;font size=&quot;3&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;107&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3. Post Comment:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; POST /api/v1/videos/{video_id}/comments&lt;/span&gt;&lt;/div&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;164&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;164&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4. Fetch Comments:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; GET /api/v1/videos/{video_id}/comments&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;222&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;222&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;5. Subscribe to Channel:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; POST /api/v1/channels/{channel_id}/subscribe&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;292&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span data-path-to-node=&quot;18&quot; data-index-in-node=&quot;292&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;6. Unsubscribe:&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; DELETE /api/v1/channels/{channel_id}/unsubscribe&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;/h2&gt;" vertex="1">
          <mxGeometry height="90" width="1290" x="2600" y="-100" as="geometry" />
        </mxCell>
        <mxCell id="8HRzVfL3QyexAWrj1ium-25" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 36px;&quot;&gt;HLD&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="60" x="2840" y="680" as="geometry" />
        </mxCell>
        <mxCell id="8HRzVfL3QyexAWrj1ium-28" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h4 data-path-to-node=&quot;4&quot;&gt;&lt;b data-path-to-node=&quot;4&quot; data-index-in-node=&quot;0&quot;&gt;The Issue: The Monolith Bottleneck&lt;/b&gt;&lt;/h4&gt;&lt;p data-path-to-node=&quot;5&quot;&gt;If you use the same server to handle &quot;User Logins&quot; and &quot;4K Video Uploads,&quot; the video upload will consume all the CPU and RAM, causing the login service to crash for everyone else.&lt;/p&gt;&lt;h4 data-path-to-node=&quot;6&quot;&gt;&lt;b data-path-to-node=&quot;6&quot; data-index-in-node=&quot;0&quot;&gt;The Solution: Microservices &amp;amp; Decoupling&lt;/b&gt;&lt;/h4&gt;&lt;p data-path-to-node=&quot;7&quot;&gt;We split the system into independent services that talk to each other through an &lt;b data-path-to-node=&quot;7&quot; data-index-in-node=&quot;81&quot;&gt;API Gateway&lt;/b&gt;.&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="470" x="3765" y="750" as="geometry" />
        </mxCell>
